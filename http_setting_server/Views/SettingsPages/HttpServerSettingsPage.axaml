<ci:SettingsPageBase x:Class="http_setting_server.Views.SettingsPages.HttpServerSettingsPage"
      xmlns="https://github.com/avaloniaui"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ci="http://classisland.tech/schemas/xaml/core"
      mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="300">
    <StackPanel Margin="20" Spacing="15">
        <TextBlock Text="HTTP 服务器设置" 
                   FontSize="20" 
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>
        
        <!-- 服务器开关 -->
        <StackPanel Spacing="5">
            <TextBlock Text="启用服务器"/>
            <CheckBox IsChecked="{Binding IsServerEnabled}"
                      Content="启用 HTTP 服务器"/>
        </StackPanel>
        
        <!-- 端口设置 -->
        <StackPanel Spacing="5">
            <TextBlock Text="端口号"/>
            <NumericUpDown Value="{Binding Port}"
                          Minimum="1024"
                          Maximum="65535"
                          Increment="1"
                          Width="200"/>
        </StackPanel>

        <!-- 鉴权设置 -->
        <StackPanel Spacing="5">
            <CheckBox IsChecked="{Binding EnableAuthentication}"
                      Content="启用 API 鉴权"/>
        </StackPanel>

        <StackPanel Spacing="5" IsEnabled="{Binding EnableAuthentication}">
            <TextBlock Text="API Token"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBox Text="{Binding AuthToken}"
                         Watermark="点击生成按钮创建 Token"
                         Grid.Column="0"
                         Margin="0,0,10,0"/>
                <Button Content="生成"
                        Command="{Binding GenerateTokenCommand}"
                        Grid.Column="1"
                        Width="80"/>
            </Grid>
            <TextBlock Text="使用方法：在 HTTP 请求头中添加 Authorization: Bearer {token}"
                       FontSize="12"
                       Foreground="Gray"
                       TextWrapping="Wrap"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- 启动通知 -->
        <StackPanel Spacing="5">
            <CheckBox IsChecked="{Binding ShowStartupNotification}"
                      Content="显示启动通知"/>
        </StackPanel>
        
        <!-- 控制按钮 -->
        <StackPanel Spacing="10" Margin="0,10,0,0">
            <Button Content="启动服务器" 
                    Command="{Binding StartServerCommand}"
                    HorizontalAlignment="Stretch"/>
            <Button Content="停止服务器" 
                    Command="{Binding StopServerCommand}"
                    HorizontalAlignment="Stretch"/>
        </StackPanel>
        
        <!-- 状态信息 -->
        <Border Padding="10" 
                Background="#F0F0F0" 
                CornerRadius="5" 
                Margin="0,10,0,0">
            <StackPanel Spacing="5">
                <TextBlock Text="服务器状态" FontWeight="Bold"/>
                <TextBlock Text="{Binding ServerStatus}"/>
            </StackPanel>
        </Border>
    </StackPanel>
</ci:SettingsPageBase>